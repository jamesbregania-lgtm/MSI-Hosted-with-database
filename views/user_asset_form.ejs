<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Add Printer Asset — MSI</title>
    <link rel="stylesheet" href="/css/user_account.css" />
</head>
<body>
    <div class="container">
        <nav class="topnav">
            <div class="topnav-brand">
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="28" height="28" rx="7" fill="var(--navy)"/>
                    <rect x="6" y="9" width="16" height="10" rx="2" fill="white" fill-opacity="0.18"/>
                    <rect x="9" y="6" width="10" height="5" rx="1.5" fill="white" fill-opacity="0.85"/>
                    <rect x="9" y="17" width="10" height="5" rx="1.5" fill="white" fill-opacity="0.85"/>
                    <circle cx="18.5" cy="14" r="1.2" fill="white"/>
                </svg>
                <span class="topnav-title">MSI</span>
            </div>

            <div class="topnav-actions">
                <!-- Back to Dashboard icon button -->
                <a href="/user_account" class="nav-icon-btn" title="Back to Dashboard" aria-label="Back to Dashboard">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="15 18 9 12 15 6"/>
                    </svg>
                </a>

                <!-- User pill -->
                <div class="nav-user-pill">
                    <div class="nav-avatar">
                        <%= currentUser.fullName.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase() %>
                    </div>
                    <div class="nav-user-info">
                        <span class="nav-user-name"><%= currentUser.fullName %></span>
                        <small class="nav-user-dept"><%= currentUser.department %></small>
                    </div>
                </div>

                <!-- Logout icon button -->
                <a href="/logout" class="nav-icon-btn nav-logout-btn" title="Logout" aria-label="Logout">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </a>
            </div>
        </nav>
        <div class="card">
            <div class="card-header">
                <div>
                    <h2>Printer Asset Form</h2>
                    <p>Choose a client and fill in the unit details.</p>
                </div>
            </div>

            <% if (success) { %>
            <div class="flash flash-success" id="flashMsg"><%= success %></div>
            <% } %>
            <% if (error) { %>
            <div class="flash flash-error" id="flashMsg"><%= error %></div>
            <% } %>

            <form id="assetForm" action="/user_account/new-machine" method="POST">
                <div class="form-grid">

                    <label for="clientInput">Client</label>
                    <div class="combo-wrap">
                        <input type="text" id="clientInput" name="clientName" autocomplete="off" placeholder="Type client name..." required>
                        <input type="hidden" id="clientId" name="clientId" value="<%= selectedClientId %>">
                        <ul id="clientDropdown" class="combo-dropdown" aria-label="Client suggestions"></ul>
                    </div>

                    <label for="unit">Unit</label>
                    <select id="unit" name="unit" required>
                        <option value="">Select a unit</option>
                        <option value="CIJ" <%= (savedAsset && savedAsset.unit === 'CIJ') ? 'selected' : '' %>>CIJ</option>
                        <option value="TTO" <%= (savedAsset && savedAsset.unit === 'TTO') ? 'selected' : '' %>>TTO</option>
                        <option value="P&A" <%= (savedAsset && savedAsset.unit === 'P&A') ? 'selected' : '' %>>P&A</option>
                        <option value="DOD" <%= (savedAsset && savedAsset.unit === 'DOD') ? 'selected' : '' %>>DOD</option>
                        <option value="LASER" <%= (savedAsset && savedAsset.unit === 'LASER') ? 'selected' : '' %>>LASER</option>
                        <option value="SUNINE" <%= (savedAsset && savedAsset.unit === 'SUNINE') ? 'selected' : '' %>>SUNINE</option>
                        <option value="ANSER" <%= (savedAsset && savedAsset.unit === 'ANSER') ? 'selected' : '' %>>ANSER</option>
                    </select>
                    <label for="model">Model</label>
                    <div class="combo-wrap model-combo-wrap">
                        <input type="text" id="model" name="model" autocomplete="off" placeholder="Search model" value="<%= savedAsset ? savedAsset.model : '' %>" required />
                        <ul id="modelDropdown" class="combo-dropdown" aria-label="Model suggestions"></ul>
                    </div>

                    <label for="serialNo">Serial No.</label>
                    <input type="text" id="serialNo" name="serialNo" placeholder="Enter serial number" value="<%= savedAsset ? savedAsset.serialNo : '' %>" required />

                    <label for="dateInstalled">Date Installed</label>
                    <input type="date" id="dateInstalled" name="dateInstalled" value="<%= savedAsset ? savedAsset.dateInstalled : '' %>" required />

                    <label for="runningHours">Running Hours</label>
                    <input type="number" id="runningHours" name="runningHours" min="0" step="1" placeholder="e.g. 1200" value="<%= savedAsset ? savedAsset.runningHours : '' %>" required />

                    <label for="status">Status</label>
                    <select id="status" name="status" required>
                        <option value="">Select status</option>
                        <option value="Active" <%= (savedAsset && savedAsset.status === 'Active') ? 'selected' : '' %>>Active</option>
                        <option value="Maintenance" <%= (savedAsset && savedAsset.status === 'Maintenance') ? 'selected' : '' %>>Maintenance</option>
                        <option value="Faulty" <%= (savedAsset && savedAsset.status === 'Faulty') ? 'selected' : '' %>>Faulty</option>
                        <option value="Inactive" <%= (savedAsset && savedAsset.status === 'Inactive') ? 'selected' : '' %>>Inactive</option>
                    </select>

                    <label for="description">Description</label>
                    <textarea id="description" name="description" rows="4" placeholder="Description"><%= savedAsset ? savedAsset.description : '' %></textarea>
                </div>

                <div style="margin-top: .8rem; display: flex; gap: .6rem; flex-wrap: wrap; align-items: center;">
                    <button type="submit" class="btn btn-primary">Submit</button>
                    <% if (savedAsset) { %>
                    <span style="color: #1e7c3a; font-weight: 500;">
                        Submitted — Unit: <%= savedAsset.unit %>, Model: <%= savedAsset.model %>, Serial: <%= savedAsset.serialNo %>
                    </span>
                    <% } %>
                </div>
            </form>
        </div>
    </div>

    <script>
        const CLIENTS = <%- JSON.stringify(clients) %>;
        const INITIAL_CLIENT_ID = '<%= selectedClientId %>';
        const PARTS_CATALOG = <%- JSON.stringify(partsCatalog || {}) %>;
    </script>
    <script src="/js/user_asset_form.js"></script>
</body>
</html>