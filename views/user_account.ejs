<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>User Account — MSI</title>
    <link rel="stylesheet" href="/css/user_account.css">
</head>
<body>
    <div class="container">
        <nav class="topnav">
            <div class="topnav-brand">
                <!-- MSI printer icon -->
                <svg width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="28" height="28" rx="7" fill="var(--navy)"/>
                    <rect x="6" y="9" width="16" height="10" rx="2" fill="white" fill-opacity="0.18"/>
                    <rect x="9" y="6" width="10" height="5" rx="1.5" fill="white" fill-opacity="0.85"/>
                    <rect x="9" y="17" width="10" height="5" rx="1.5" fill="white" fill-opacity="0.85"/>
                    <circle cx="18.5" cy="14" r="1.2" fill="white"/>
                </svg>
                <span class="topnav-title">MSI</span>
            </div>

            <div class="topnav-actions">
                <!-- Add Printer icon button -->
                <a href="/user_account/new-machine" class="nav-icon-btn" title="Add Printer Asset" aria-label="Add Printer Asset">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="6" y="9" width="12" height="8" rx="2"/>
                        <path d="M8 9V6a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v3"/>
                        <path d="M8 17v1a2 2 0 0 0 2 2h4a2 2 0 0 0 2-2v-1"/>
                        <line x1="12" y1="4" x2="12" y2="4"/>
                    </svg>
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" class="plus-badge">
                        <circle cx="5" cy="5" r="5" fill="#2a6499"/>
                        <path d="M5 2.5v5M2.5 5h5" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                </a>

                <!-- User pill -->
                <div class="nav-user-pill">
                    <div class="nav-avatar">
                        <%= currentUser.fullName.split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase() %>
                    </div>
                    <div class="nav-user-info">
                        <span class="nav-user-name"><%= currentUser.fullName %></span>
                        <small class="nav-user-dept"><%= currentUser.department %></small>
                    </div>
                </div>

                <!-- Logout icon button -->
                <a href="/logout" class="nav-icon-btn nav-logout-btn" title="Logout" aria-label="Logout">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </a>
            </div>
        </nav>

        <div id="client-section" class="client-section">
        <div class="card">
            <div class="card-header">
                <div>
                        <h2>Partnership Clients</h2>
                        <p>Select a client to view their unit records.</p>
            </div>
                    <div class="search-wrap">
                        <svg class="search-icon" width="15" height="15" viewBox="0 0 15 15" fill="none">
                            <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.4"/>
                            <path d="M10 10l3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                        </svg>
                        <input
                            type="text"
                            id="clientSearch"
                            placeholder="Search client..."
                            oninput="filterClients()"
                        />
                    </div>
                </div>

                <div class="client-list-head">
                    <span class="col-num">#</span>
                    <span class="col-name">Client Name</span>
                    <span class="col-badge">Location</span>
                    <span class="col-arrow"></span>
                </div>

                <div class="client-list" id="client-grid"></div>
            </div>
        </div>
    </div>

    <script>
        const CLIENTS = <%- JSON.stringify(clients) %>;
    </script>
    <script src="/js/user_account.js"></script>
</body>
</html>