# Port is 3000 for your computer, Render will ignore this and use its own
PORT=3000

# Use a long random string for security
SESSION_SECRET=a_very_long_random_string_12345!

# Set to development for your PC, change to production in Render settings
NODE_ENV=development

# Your Google Apps Script URL
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbwhiaNNVRcaNdQ8Xj2zloaBivlAsUzKKWfl5yxV1YiFeJC-Pi6XJBtafDfFwnYktulr/exec
